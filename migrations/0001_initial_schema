-- Migration: 0001_initial_schema
-- Replaces the template comments table with the campervan alert schema.
-- Run with: npx wrangler d1 migrations apply d1_camper --remote

DROP TABLE IF EXISTS comments;

-- ─── Users ────────────────────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS users (
  id                  TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
  email               TEXT,
  phone               TEXT,
  whatsapp            TEXT,
  notify_preference   TEXT NOT NULL DEFAULT 'email',  -- 'email' | 'sms' | 'whatsapp' | 'push'
  created_at          TEXT NOT NULL DEFAULT (datetime('now'))
);

-- ─── Alerts ───────────────────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS alerts (
  id                        TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
  user_id                   TEXT NOT NULL REFERENCES users(id),
  from_city                 TEXT NOT NULL,
  to_city                   TEXT NOT NULL,
  travel_date_start         TEXT NOT NULL,  -- ISO date: '2026-03-01'
  travel_date_end           TEXT NOT NULL,  -- ISO date: '2026-03-31'
  vehicle_type              TEXT,           -- null = any type
  max_price_per_day         REAL,           -- null = any price
  status                    TEXT NOT NULL DEFAULT 'active',   -- 'active' | 'paused' | 'expired'
  notify_mode               TEXT NOT NULL DEFAULT 'instant', -- 'instant' | 'digest'
  max_notifications_per_day INTEGER DEFAULT 3,
  last_notified_at          TEXT,
  expires_at                TEXT NOT NULL,
  created_at                TEXT NOT NULL DEFAULT (datetime('now')),
  updated_at                TEXT NOT NULL DEFAULT (datetime('now'))
);

-- ─── Listings ─────────────────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS listings (
  id              TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
  source_site     TEXT NOT NULL,    -- 'transfercar' | 'imove' | etc
  from_city       TEXT NOT NULL,
  to_city         TEXT NOT NULL,
  available_date  TEXT NOT NULL,    -- ISO date
  vehicle_type    TEXT,
  price_per_day   REAL NOT NULL,
  listing_url     TEXT,
  first_seen_at   TEXT NOT NULL DEFAULT (datetime('now')),
  last_seen_at    TEXT NOT NULL DEFAULT (datetime('now')),
  is_active       INTEGER NOT NULL DEFAULT 1  -- 0 when listing disappears from source
);

-- ─── Notifications ────────────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS notifications (
  id          TEXT PRIMARY KEY DEFAULT (lower(hex(randomblob(16)))),
  alert_id    TEXT NOT NULL REFERENCES alerts(id),
  listing_id  TEXT NOT NULL REFERENCES listings(id),
  channel     TEXT NOT NULL,   -- 'email' | 'sms' | 'whatsapp' | 'push'
  payload     TEXT,            -- JSON blob: message + listing details
  status      TEXT NOT NULL DEFAULT 'pending',  -- 'pending' | 'sent' | 'failed'
  sent_at     TEXT NOT NULL DEFAULT (datetime('now'))
);

-- ─── Indexes ──────────────────────────────────────────────────────────────
-- These are not optional — without them the matching JOIN full-scans at scale

CREATE INDEX IF NOT EXISTS idx_listings_route
  ON listings(from_city, to_city, available_date);

CREATE INDEX IF NOT EXISTS idx_listings_seen
  ON listings(first_seen_at);

CREATE INDEX IF NOT EXISTS idx_listings_active
  ON listings(is_active);

CREATE INDEX IF NOT EXISTS idx_alerts_status
  ON alerts(status, expires_at);

-- Delta check index: alert_id + listing_id lookup
CREATE INDEX IF NOT EXISTS idx_notifications_delta
  ON notifications(alert_id, listing_id);

-- Daily cap index: alert_id + date lookup
CREATE INDEX IF NOT EXISTS idx_notifications_daily
  ON notifications(alert_id, sent_at);
